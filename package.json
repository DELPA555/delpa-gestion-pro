{
  "name": "panel-financiero",
  "version": "1.4.0",
  "private": true,
  "main": "main/index.js",
  "scripts": {
    "dev": "concurrently \"vite --config renderer/vite.config.js\" \"wait-on http://localhost:5173 && cross-env NODE_ENV=development electron .\"",
    "build:renderer": "vite build --config renderer/vite.config.js",
    "build": "npm run build:renderer && electron-builder",
    "dist": "npm run build",
    "rebuild": "electron-rebuild -f -w better-sqlite3"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "clsx": "^2.1.1",
    "cross-env": "^7.0.3",
    "electron-store": "^8.2.0",
    "electron-updater": "^6.8.3",
    "framer-motion": "^12.39.0",
    "googleapis": "^172.0.0",
    "jsbarcode": "^3.12.3",
    "lucide-react": "^0.525.0",
    "node-cron": "^4.2.1",
    "node-forge": "^1.4.0",
    "nodemailer": "^8.0.7",
    "qrcode": "^1.5.4",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-router-dom": "^7.6.0",
    "recharts": "^2.15.3",
    "soap": "^1.9.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^3.7.1",
    "@tailwindcss/vite": "^4.1.7",
    "@vitejs/plugin-react": "^4.5.0",
    "concurrently": "^9.2.1",
    "electron": "^37.2.0",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9",
    "tailwindcss": "^4.1.7",
    "vite": "^6.3.5",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.delpa.gestionpro",
    "productName": "DELPA Gestion PRO",
    "directories": {
      "output": "C:\\builds\\delpa"
    },
    "files": [
      "main/**",
      "renderer/dist/**",
      "database/**",
      "node_modules/**"
    ],
    "win": {
      "target": "nsis",
      "icon": "public/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "DELPA-Gestion-PRO-Setup.exe"
    },
    "publish": {
      "provider": "github",
      "owner": "DELPA555",
      "repo": "delpa-gestion-pro",
      "releaseType": "release"
    },
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**"
    ]
  }
}
